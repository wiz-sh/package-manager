{
    "name": "@wiz-sh/runtime",
    "version": "0.1.0",
    "description": "Executable resolution and command runtime for Wiz",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/wiz-sh/package-manager.git",
        "directory": "packages/runtime"
    },
    "homepage": "https://github.com/wiz-sh/package-manager#readme",
    "type": "module",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm && tsc --project ./tsconfig.build.json"
    },
    "dependencies": {
        "@wiz-sh/pm": "^0.1.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "bun": ">=1.2.0"
    }
}
